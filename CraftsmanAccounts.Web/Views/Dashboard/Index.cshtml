@model CraftsmanAccounts.Web.Models.ViewModels.DashboardViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "الرئيسية";
}

<div class="dashboard-stats animate__animated animate__fadeIn">
    <div class="row g-4">
        <!-- Total Users -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@Model.TotalUsers">0</h3>
                        <p class="stat-label">إجمالي المستخدمين</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "Users")">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Active Users -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-success">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-user-check"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@Model.ActiveUsers">0</h3>
                        <p class="stat-label">المستخدمون النشطون</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "Users", new { IsActive = true })">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Approvals -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-warning">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@Model.PendingApprovals">0</h3>
                        <p class="stat-label">بانتظار الموافقة</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "UserApprovals")">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-info">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-money-bill-wave"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@((int)Model.TotalRevenue)">0</h3>
                        <p class="stat-label">إجمالي الإيرادات (د.ع)</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "UserSubscriptions")">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Subscriptions -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-purple">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@Model.TotalSubscriptions">0</h3>
                        <p class="stat-label">إجمالي الاشتراكات</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "UserSubscriptions")">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Active Subscriptions -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card stat-card-teal">
                <div class="stat-card-body">
                    <div class="stat-icon">
                        <i class="fas fa-check-double"></i>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-number" data-count="@Model.ActiveSubscriptions">0</h3>
                        <p class="stat-label">الاشتراكات النشطة</p>
                    </div>
                </div>
                <div class="stat-card-footer">
                    <a href="@Url.Action("Index", "UserSubscriptions", new { Status = 1 })">
                        <span>عرض التفاصيل</span>
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Subscriptions Table -->
<div class="dashboard-section animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
    <div class="section-card">
        <div class="section-header">
            <h5><i class="fas fa-history me-2"></i> آخر الاشتراكات</h5>
            <a href="@Url.Action("Index", "UserSubscriptions")" class="btn btn-sm btn-outline-primary">عرض الكل</a>
        </div>
        <div class="section-body">
            @if (Model.RecentSubscriptions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>المستخدم</th>
                                <th>نوع الاشتراك</th>
                                <th>المبلغ</th>
                                <th>تاريخ البداية</th>
                                <th>الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in Model.RecentSubscriptions)
                            {
                                <tr class="table-row-animated">
                                    <td>
                                        <div class="user-cell">
                                            <div class="user-avatar-sm">
                                                <i class="fas fa-user"></i>
                                            </div>
                                            <span>@sub.UserName</span>
                                        </div>
                                    </td>
                                    <td>@sub.SubscriptionTypeName</td>
                                    <td><span class="text-primary fw-bold">@sub.Amount.ToString("N0") د.ع</span></td>
                                    <td>@sub.StartDate.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        @switch (sub.Status)
                                        {
                                            case CraftsmanAccounts.Web.Models.SubscriptionStatus.Pending:
                                                <span class="status-badge status-pending">بانتظار الموافقة</span>
                                                break;
                                            case CraftsmanAccounts.Web.Models.SubscriptionStatus.Approved:
                                                <span class="status-badge status-approved">تمت الموافقة</span>
                                                break;
                                            case CraftsmanAccounts.Web.Models.SubscriptionStatus.Rejected:
                                                <span class="status-badge status-rejected">مرفوض</span>
                                                break;
                                            case CraftsmanAccounts.Web.Models.SubscriptionStatus.Paid:
                                                <span class="status-badge status-paid">تم الدفع</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>لا توجد اشتراكات حتى الآن</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Animate stat numbers
            document.querySelectorAll('.stat-number').forEach(function (el) {
                const target = parseInt(el.getAttribute('data-count'));
                const duration = 1500;
                const step = target / (duration / 16);
                let current = 0;

                const timer = setInterval(function () {
                    current += step;
                    if (current >= target) {
                        current = target;
                        clearInterval(timer);
                    }
                    el.textContent = Math.floor(current).toLocaleString('ar-EG');
                }, 16);
            });
        });
    </script>
}
