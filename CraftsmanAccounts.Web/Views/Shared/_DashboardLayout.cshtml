@{
    Layout = null;
    var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? "المدير";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var pendingCount = ViewBag.PendingCount as int? ?? 0;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body class="dashboard-body">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <i class="fas fa-gem"></i>
                <span class="sidebar-brand">Craftsman</span>
            </div>
            <button class="sidebar-close d-lg-none" id="sidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <nav class="sidebar-nav">
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item @(currentController == "Dashboard" ? "active" : "")">
                    <a href="@Url.Action("Index", "Dashboard")">
                        <i class="fas fa-home"></i>
                        <span>الرئيسية</span>
                    </a>
                </li>
                <li class="sidebar-menu-item @(currentController == "Users" ? "active" : "")">
                    <a href="@Url.Action("Index", "Users")">
                        <i class="fas fa-users"></i>
                        <span>المستخدمون</span>
                    </a>
                </li>
                <li class="sidebar-menu-item @(currentController == "UserApprovals" ? "active" : "")">
                    <a href="@Url.Action("Index", "UserApprovals")">
                        <i class="fas fa-user-check"></i>
                        <span>موافقة المستخدمين</span>
                        <span class="sidebar-badge" id="pendingBadge" style="@(pendingCount == 0 ? "display:none" : "")">@pendingCount</span>
                    </a>
                </li>
                <li class="sidebar-menu-item @(currentController == "SubscriptionTypes" ? "active" : "")">
                    <a href="@Url.Action("Index", "SubscriptionTypes")">
                        <i class="fas fa-tags"></i>
                        <span>أنواع الاشتراكات</span>
                    </a>
                </li>
                <li class="sidebar-menu-item @(currentController == "UserSubscriptions" ? "active" : "")">
                    <a href="@Url.Action("Index", "UserSubscriptions")">
                        <i class="fas fa-credit-card"></i>
                        <span>اشتراكات المستخدمين</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div class="sidebar-user-info">
                    <span class="sidebar-user-name">@displayName</span>
                    <span class="sidebar-user-role">مدير النظام</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper" id="mainWrapper">
        <!-- Top Navbar -->
        <nav class="top-navbar">
            <div class="top-navbar-right">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h5 class="page-title mb-0">@ViewData["Title"]</h5>
            </div>
            <div class="top-navbar-left">
                <div class="notification-wrapper" id="notificationWrapper">
                    <button class="notification-btn" id="notificationBtn">
                        <i class="fas fa-bell"></i>
                        <span class="notification-count" id="notificationCount" style="display:none">0</span>
                    </button>
                    <div class="notification-dropdown" id="notificationDropdown">
                        <div class="notification-header">
                            <h6>الإشعارات</h6>
                            <button class="clear-notifications" id="clearNotifications">مسح الكل</button>
                        </div>
                        <div class="notification-list" id="notificationList">
                            <div class="notification-empty">
                                <i class="fas fa-bell-slash"></i>
                                <p>لا توجد إشعارات</p>
                            </div>
                        </div>
                    </div>
                </div>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn" title="تسجيل الخروج">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Page Content -->
        <div class="page-content">
            @if (TempData["Success"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show animate__animated animate__fadeInDown" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show animate__animated animate__fadeInDown" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/export-print.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
