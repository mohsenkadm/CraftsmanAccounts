@model CraftsmanAccounts.Web.Models.SubscriptionType
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "تعديل نوع الاشتراك";
}

<div class="page-header animate__animated animate__fadeIn">
    <div class="page-header-content">
        <h4><i class="fas fa-edit me-2"></i> تعديل نوع الاشتراك</h4>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-right me-1"></i> رجوع
        </a>
    </div>
</div>

<div class="section-card animate__animated animate__fadeInUp" style="max-width: 700px;">
    <div class="section-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="mb-4">
                <label class="form-label fw-medium">اسم الاشتراك</label>
                <div class="input-icon-wrapper">
                    <i class="fas fa-tag input-icon"></i>
                    <input asp-for="Name" class="form-control form-control-custom" />
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-medium">المبلغ (د.ع)</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-money-bill input-icon"></i>
                        <input asp-for="Amount" type="number" step="1000" class="form-control form-control-custom" />
                    </div>
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">المدة (بالأيام)</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-calendar input-icon"></i>
                        <input asp-for="DurationInDays" type="number" class="form-control form-control-custom" />
                    </div>
                    <span asp-validation-for="DurationInDays" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-medium">التفاصيل</label>
                <textarea asp-for="Details" class="form-control form-control-custom" rows="4"></textarea>
                <span asp-validation-for="Details" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch form-switch-custom">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">فعّال</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary-custom">
                    <i class="fas fa-save me-2"></i> حفظ التعديلات
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </form>
    </div>
</div>
