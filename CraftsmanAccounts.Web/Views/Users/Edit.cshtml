@model CraftsmanAccounts.Web.Models.AppUser
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "تعديل بيانات المستخدم";
}

<div class="page-header animate__animated animate__fadeIn">
    <div class="page-header-content">
        <h4><i class="fas fa-user-edit me-2"></i> تعديل بيانات المستخدم</h4>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-right me-1"></i> رجوع
        </a>
    </div>
</div>

<div class="section-card animate__animated animate__fadeInUp" style="max-width: 700px;">
    <div class="section-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ApprovalStatus" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="mb-4">
                <label class="form-label fw-medium">الاسم الكامل</label>
                <div class="input-icon-wrapper">
                    <i class="fas fa-user input-icon"></i>
                    <input asp-for="FullName" class="form-control form-control-custom" placeholder="أدخل الاسم الكامل" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-medium">العنوان</label>
                <div class="input-icon-wrapper">
                    <i class="fas fa-map-marker-alt input-icon"></i>
                    <input asp-for="Address" class="form-control form-control-custom" placeholder="أدخل العنوان" />
                </div>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-medium">رقم الهاتف</label>
                <div class="input-icon-wrapper">
                    <i class="fas fa-phone input-icon"></i>
                    <input asp-for="PhoneNumber" class="form-control form-control-custom" placeholder="أدخل رقم الهاتف" dir="ltr" />
                </div>
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch form-switch-custom">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">المستخدم نشط</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary-custom">
                    <i class="fas fa-save me-2"></i> حفظ التعديلات
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </form>
    </div>
</div>
